# Copy to `.env` for local development. Never commit the real `.env`
# (PLAN §17.5, CLAUDE.md §15.1). Values below match `infra/docker-compose.yml`.

# --- APP_* ---------------------------------------------------------------
APP_NAME=crediwise-backend
APP_ENV=local
APP_DEBUG=true
APP_CORRELATION_HEADER=X-Correlation-Id

# --- DB_* ------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crediwise
DB_USER=crediwise
DB_PASSWORD=crediwise_local_dev_only
DB_POOL_SIZE=5

# --- REDIS_* -----------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# --- STORAGE_* (S3-compatible; MinIO locally — PLAN §16.1, §17.3) ----------
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=crediwise-local
STORAGE_ACCESS_KEY=crediwise
STORAGE_SECRET_KEY=crediwise_local_dev_only
STORAGE_USE_SSL=false

# --- SECURITY_* (RS256 JWT signing — PLAN §18.1) ----------------------------
# Generate a local dev keypair with `make backend-generate-jwt-keys`, then
# paste the two printed lines below into your real `.env`. Never commit real
# key material (PLAN §17.5, CLAUDE.md §15.1).
SECURITY_JWT_PRIVATE_KEY=
SECURITY_JWT_PUBLIC_KEY=
SECURITY_JWT_KID=local-dev-1
SECURITY_ACCESS_TOKEN_TTL_MINUTES=15
SECURITY_REFRESH_TOKEN_TTL_DAYS=30

# --- Upload file-security limits (PLAN §7.2, FR-3 AC2/AC5) ------------------
MAX_UPLOAD_MB=15
MAX_PDF_PAGES=60
MAX_IMAGE_PIXELS=25000000
